# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"

# Solo se usa server-side (webhook, descarga de archivos). NUNCA exponer
# esta clave al browser ni prefijarla con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# Mercado Pago (Panel de desarrolladores → Credenciales)
MERCADOPAGO_ACCESS_TOKEN="tu-access-token"
MERCADOPAGO_WEBHOOK_SECRET="tu-clave-secreta-de-webhook"

# URL pública del sitio, usada para armar la notification_url del webhook.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
